# Адрес будущего бэкенда (FastAPI). Пока не используется — фронт работает на localStorage,
# но переменная уже здесь, чтобы потом было легко подключить реальный API.
VITE_API_BASE_URL=http://localhost:8000/api

# Переключатель между моком (localStorage) и реальным бэком.
# Когда бэкенд будет готов — поставить значение "false".
VITE_USE_MOCK_API=true
